const barData = [
  {name:'C++',pct:88},
  {name:'Power BI',pct:85},
  {name:'Python',pct:80},
  {name:'SQL',pct:82},
  {name:'Tableau',pct:78},
  {name:'Excel',pct:90},
  {name:'Data Analysis',pct:86}
];

const projects = [
  {
    id:1, cat:'C++ Engineering', featured:true,
    icon:'⚙️',
    title:'Finance Flare',
    desc:'A high-performance C++ financial management system with real-time analytics, integrated with Power BI dashboards for visualisation.',
    tags:['C++','Power BI','Financial','OOP'],
    gh:'https://github.com/HusseinHany',
    live:null
  },
  {
    id:2, cat:'Data Analytics', featured:false,
    icon:'📊',
    title:'Sales Analytics Dashboard',
    desc:'Interactive Power BI dashboard analysing sales performance across regions with drill-through capabilities and KPI monitoring.',
    tags:['Power BI','DAX','SQL','Excel'],
    gh:'https://github.com/HusseinHany',
    live:null
  },
  {
    id:3, cat:'Data Analytics', featured:false,
    icon:'📈',
    title:'Market Trend Analysis',
    desc:'Python-powered market data analysis using Pandas and Matplotlib to uncover trends and generate automated reports.',
    tags:['Python','Pandas','Matplotlib','Jupyter'],
    gh:'https://github.com/HusseinHany',
    live:null
  },
  {
    id:4, cat:'C++ Engineering', featured:false,
    icon:'🔷',
    title:'Data Structures Library',
    desc:'Optimised C++ library implementing core data structures and algorithms with extensive unit testing and benchmarks.',
    tags:['C++','Algorithms','OOP','Testing'],
    gh:'https://github.com/HusseinHany',
    live:null
  }
];

const tools = ['C++','C#','Python','Java','SQL','Excel','Power BI','Tableau','Problem Solving','Data Analysis','Pandas','NumPy','Matplotlib','Git','Linux','R'];
const langColors = {
  'JavaScript':'#f1e05a','Python':'#3572A5','C++':'#f34b7d','C#':'#178600',
  'Java':'#b07219','HTML':'#e34c26','CSS':'#563d7c','TypeScript':'#2b7489',
  'R':'#198CE7','Shell':'#89e051','Ruby':'#701516','Go':'#00ADD8',
  'Jupyter Notebook':'#DA5B0B','SQL':'#e38c00'
};

// ---- NAV ----
window.addEventListener('scroll',()=>{
  const nav = document.getElementById('nav');
  nav.classList.toggle('solid', window.scrollY > 60);
  const p = window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100;
  document.getElementById('prog').style.width = Math.min(p,100) + '%';
});

function goTo(id){
  const el = document.getElementById(id);
  if(el) el.scrollIntoView({behavior:'smooth',block:'start'});
}

// ---- MOBILE MENU ----
let menuOpen = false;
function toggleMenu(){
  menuOpen = !menuOpen;
  const hb = document.getElementById('hamburger');
  hb.classList.toggle('open', menuOpen);
  hb.setAttribute('aria-expanded', menuOpen);
  document.getElementById('mobileMenu').classList.toggle('open', menuOpen);
  document.body.style.overflow = menuOpen ? 'hidden' : '';
}
function closeMobileMenu(){
  menuOpen = false;
  document.getElementById('hamburger').classList.remove('open');
  document.getElementById('mobileMenu').classList.remove('open');
  document.body.style.overflow = '';
}

// ---- TYPEWRITER ----
const msgs = [
  'Turning raw data into strategic insights',
  'Building robust C++ systems that scale',
  'From spreadsheets to Power BI dashboards',
  'Bridging engineering and analytics'
];
let mi=0, ci=0, del=false;
const typedEl = document.getElementById('typed');
function type(){
  const s = msgs[mi];
  if(!del){
    typedEl.textContent = s.slice(0, ++ci);
    if(ci === s.length){ del = true; setTimeout(type, 2000); return; }
  } else {
    typedEl.textContent = s.slice(0, --ci);
    if(ci === 0){ del = false; mi = (mi+1) % msgs.length; }
  }
  setTimeout(type, del ? 40 : 70);
}
setTimeout(type, 1200);

// ---- COUNTERS ----
function animateCounter(el, target){
  let v = 0;
  const step = Math.ceil(target / 40);
  const t = setInterval(()=>{
    v = Math.min(v + step, target);
    el.textContent = v + '+';
    if(v >= target) clearInterval(t);
  }, 35);
}

// ---- INTERSECTION OBSERVER ----
const obs = new IntersectionObserver(entries=>{
  entries.forEach(en=>{
    if(en.isIntersecting){
      en.target.classList.add('in');
      obs.unobserve(en.target);
    }
  });
},{threshold:0.15});
document.querySelectorAll('.fade-up,.fade-left,.fade-right,.stagger-child').forEach(el=>obs.observe(el));

// Stat counters via separate observer
const statObs = new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){
    animateCounter(document.getElementById('stat-projects'), 5);
    animateCounter(document.getElementById('stat-tools'), 12);
    animateCounter(document.getElementById('stat-repos'), 10);
    statObs.disconnect();
  }
},{threshold:0.5});
statObs.observe(document.querySelector('.hero-stats'));

// ---- SKILL TABS ----
let curTab = 0;
function swTab(i, btn){
  curTab = i;
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  renderTab();
}
function renderTab(){
  const sk = tabs[curTab].skills;
  document.getElementById('tab-content').innerHTML =
    '<div class="skills-grid">' +
    sk.map(s=>`<div class="skill-chip stagger-child"><span class="skill-icon">${s.icon}</span>${s.name}</div>`).join('') +
    '</div>';
  document.querySelectorAll('#tab-content .stagger-child').forEach((el,i)=>{
    el.style.transitionDelay = (i * 0.05) + 's';
    obs.observe(el);
  });
}
renderTab();

// ---- MARQUEE ----
const mqEl = document.getElementById('mq');
const doubled = [...tools,...tools];
mqEl.innerHTML = doubled.map(t=>`<span class="mq-item">◈ ${t}</span>`).join('');

// ---- SKILL BARS ----
function buildBars(){
  const w = document.getElementById('bars');
  w.innerHTML = barData.map(b=>
    `<div class="bar-row">
      <div class="bar-name">${b.name}</div>
      <div class="bar-track"><div class="bar-fill" data-pct="${b.pct/100}"></div></div>
      <div class="bar-pct">${b.pct}%</div>
    </div>`
  ).join('');
}
buildBars();

const barsObs = new IntersectionObserver(entries=>{
  if(entries[0].isIntersecting){
    document.querySelectorAll('.bar-fill').forEach(f=>{
      f.style.transform = `scaleX(${f.dataset.pct})`;
    });
    barsObs.disconnect();
  }
},{threshold:0.3});
barsObs.observe(document.querySelector('.bars-card'));

// ---- PROJECTS ----
let activeCat = 'All';
function filterProjects(cat, btn){
  activeCat = cat;
  document.querySelectorAll('.fp').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  renderProjects();
}
function renderProjects(){
  const list = activeCat === 'All' ? projects : projects.filter(p=>p.cat===activeCat);
  document.getElementById('pgrid').innerHTML = list.map(p=>`
    <div class="proj-card stagger-child">
      <div class="proj-img-wrap">
        <div class="proj-img-placeholder">${p.icon}</div>
        ${p.featured?'<div class="feat-badge">★ Featured</div>':''}
      </div>
      <div class="proj-body">
        <div class="proj-cat">${p.cat}</div>
        <div class="proj-title">${p.title}</div>
        <div class="proj-desc">${p.desc}</div>
        <div class="proj-tags">${p.tags.map(t=>`<span class="proj-tag">${t}</span>`).join('')}</div>
        <div class="proj-links">
          ${p.gh?`<a href="${p.gh}" target="_blank" rel="noopener" class="proj-link proj-link-gh">🐙 GitHub</a>`:''}
          ${p.live?`<a href="${p.live}" target="_blank" rel="noopener" class="proj-link proj-link-live">🔗 Live Demo</a>`:''}
        </div>
      </div>
    </div>
  `).join('');
  document.querySelectorAll('#pgrid .stagger-child').forEach((el,i)=>{
    el.style.transitionDelay = (i * 0.1) + 's';
    obs.observe(el);
  });
}
renderProjects();

// ---- GITHUB REPOS ----
const GH_USER = 'HusseinHany';
const GH_REPO_SITE = GH_USER + '.github.io';
async function loadRepos(){
  try{
    const res = await fetch('https://api.github.com/users/' + GH_USER + '/repos?sort=updated&per_page=9&type=public');
    if(!res.ok) throw new Error('API error');
    const repos = await res.json();
    renderRepos(repos.filter(r=>!r.fork && r.name !== GH_REPO_SITE).slice(0,8));
    animateCounter(document.getElementById('stat-repos'), repos.length);
  } catch(err){
    document.getElementById('repo-loading').innerHTML = '<span style="opacity:.5">Repositories will be displayed once the page is live on GitHub Pages.</span>';
  }
}

function escHtml(s){
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderRepos(repos){
  const loading = document.getElementById('repo-loading');
  const grid = document.getElementById('repo-grid');
  if(!repos || repos.length === 0){
    loading.innerHTML = '<span style="opacity:.5">No public repositories found.</span>';
    return;
  }
  loading.style.display = 'none';
  grid.style.display = 'grid';
  grid.innerHTML = repos.map(r=>`
    <a href="${escHtml(r.html_url)}" target="_blank" rel="noopener noreferrer" class="repo-card stagger-child">
      <div class="repo-name">
        <span class="repo-name-icon">📁</span>
        ${escHtml(r.name)}
      </div>
      <div class="repo-desc">${escHtml(r.description || 'No description available.')}</div>
      <div class="repo-meta">
        ${r.language?`<span class="repo-lang">
          <span class="repo-lang-dot" style="background:${escHtml(langColors[r.language]||'var(--muted)')}"></span>
          ${escHtml(r.language)}
        </span>`:''}
        ${r.stargazers_count>0?`<span class="repo-stars">⭐ ${Number(r.stargazers_count)}</span>`:''}
        ${r.forks_count>0?`<span>🍴 ${Number(r.forks_count)}</span>`:''}
      </div>
    </a>
  `).join('');
  document.querySelectorAll('#repo-grid .stagger-child').forEach((el,i)=>{
    el.style.transitionDelay = (i * 0.07) + 's';
    obs.observe(el);
  });
}
loadRepos();

// ---- FORM ----
function updateCount(el){
  document.getElementById('fcount').textContent = Math.min(el.value.length, 500);
}

function validateForm(form){
  let valid = true;
  const name = form.querySelector('#fname');
  const email = form.querySelector('#femail');
  const msg = form.querySelector('#fmsg');
  [name, email, msg].forEach(f=>f.classList.remove('error'));
  if(!name.value.trim()){ name.classList.add('error'); valid = false; }
  if(!email.value.trim() || !/^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)+$/.test(email.value)){ email.classList.add('error'); valid = false; }
  if(!msg.value.trim()){ msg.classList.add('error'); valid = false; }
  return valid;
}

async function submitForm(e){
  e.preventDefault();
  if(!validateForm(e.target)) return;
  const btn = document.getElementById('fsub');
  const status = document.getElementById('form-status');
  btn.textContent = 'Sending…';
  btn.disabled = true;
  status.className = 'form-status';
  status.style.display = 'none';

  const formData = {
    name: e.target.querySelector('#fname').value.trim(),
    email: e.target.querySelector('#femail').value.trim(),
    message: e.target.querySelector('#fmsg').value.trim()
  };

  try{
    const res = await fetch('https://formsubmit.co/ajax/hussein27007@gmail.com', {
      method:'POST',
      headers:{'Content-Type':'application/json','Accept':'application/json'},
      body: JSON.stringify(formData)
    });
    const data = await res.json();
    if(res.ok && (data.success === 'true' || data.success === true)){
      btn.textContent = 'Message Sent ✓';
      btn.style.background = 'var(--em2)';
      e.target.reset();
      document.getElementById('fcount').textContent = '0';
      const t = document.getElementById('toast');
      t.classList.add('show');
      setTimeout(()=>t.classList.remove('show'), 4000);
      setTimeout(()=>{ btn.textContent = 'Send Message →'; btn.disabled = false; btn.style.background = ''; }, 3000);
    } else {
      throw new Error('Send failed');
    }
  } catch(err){
    status.textContent = '⚠ Could not send message. Please email hussein27007@gmail.com directly.';
    status.className = 'form-status error';
    btn.textContent = 'Send Message →';
    btn.disabled = false;
  }
}

// ---- SMOOTH SCROLL for anchor links ----
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click', e=>{
    const id = a.getAttribute('href').slice(1);
    const el = document.getElementById(id);
    if(el){ e.preventDefault(); el.scrollIntoView({behavior:'smooth',block:'start'}); }
  });
});
